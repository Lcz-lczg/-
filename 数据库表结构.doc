<h3>&nbsp;
    创建外键索引语句:
</h3>

<pre style="padding: 20px; display: block; background: #d5d5d5;font-size: 12px">
;
ALTER TABLE pinglunhuifu ADD FOREIGN KEY (pinglunid) REFERENCES pinglun(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE xinwengonggao ADD FOREIGN KEY (fenlei) REFERENCES xinwenfenlei(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE qiuyuanxinxi ADD FOREIGN KEY (suoshuqiudui) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaixinxi ADD FOREIGN KEY (bisaileixing) REFERENCES bisaileixing(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaibaoming ADD FOREIGN KEY (bisaixinxiid) REFERENCES bisaixinxi(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaibaoming ADD FOREIGN KEY (bisaileixing) REFERENCES bisaileixing(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaibaoming ADD FOREIGN KEY (baomingqiudui) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE saichengbiao ADD FOREIGN KEY (bisaixinxiid) REFERENCES bisaixinxi(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE saichengbiao ADD FOREIGN KEY (bisaileixing) REFERENCES bisaileixing(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE saichengbiao ADD FOREIGN KEY (qiuduia) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE saichengbiao ADD FOREIGN KEY (qiuduib) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaiwancheng ADD FOREIGN KEY (saichengbiaoid) REFERENCES saichengbiao(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaiwancheng ADD FOREIGN KEY (bisaileixing) REFERENCES bisaileixing(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaiwancheng ADD FOREIGN KEY (qiuduia) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaiwancheng ADD FOREIGN KEY (qiuduib) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE;
ALTER TABLE bisaiwancheng ADD FOREIGN KEY (shengliqiudui) REFERENCES qiudui(id) ON UPDATE CASCADE ON DELETE CASCADE</pre>
